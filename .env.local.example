# ============================================================
# GURU — World Cup 2026 Trivia
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ------- Supabase -------
# Get from: https://supabase.com/dashboard/project/<project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key

# Service role key — server-side only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key

# ------- Anthropic -------
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ------- Football Data -------
# Get from: https://www.football-data.org/client/register
# Free tier: 10 req/min, World Cup data included
FOOTBALL_DATA_API_KEY=your_football_data_api_key

# ------- Cron Security -------
# Random secret to protect the /api/matches/sync endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-32-char-secret

# ------- Stripe (Post-MVP) -------
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
