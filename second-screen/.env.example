# Server
PORT=3001
NODE_ENV=development

# ESPN API
# Public ESPN API requires no key for basic data.
# If you have a key from ESPN partner access, set it here.
ESPN_API_BASE_URL=https://site.api.espn.com/apis/site/v2/sports/soccer
ESPN_API_KEY=
# La Liga = esp.1
ESPN_LEAGUE=esp.1
# The ESPN event ID for the Atletico vs Barcelona match.
# Find it at: https://www.espn.com/soccer/ and grab the event ID from the URL.
ESPN_MATCH_ID=

# Engine
# Set to true to run fully in simulation mode (no ESPN calls required)
USE_MOCKS=true
# How often the polling service ticks (ms). Not used in MVP — tick is manual via POST /tick.
POLL_INTERVAL_MS=15000
